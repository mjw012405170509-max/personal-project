<?xml version="1.0" encoding="UTF-8" ?>

<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.main.personalprojectback.dao.UserDao">

    <insert id="signIn">
        insert into user_tbl(user_id,password,role,created_at,status) values(#{userId},#{password},'user',current_date,'pending')
    </insert>
    <select id="idCheck" resultType="java.lang.Integer">
        select count(*) from user_tbl where user_id = #{userId}
    </select>
    <select id="getLoginInfo" resultType="com.main.personalprojectback.DTO.LoginInfoDto">
        select user_id,password,role,status from user_tbl where user_id=#{userId}
    </select>
</mapper>